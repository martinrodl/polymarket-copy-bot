# Trading mode: "paper" (default) or "live"
MODE=paper

# Budget
BANKROLL=100.0
MAX_TRADE_SIZE=5.0

# Polymarket API credentials (required for live trading only)
# Get from: https://polymarket.com → Settings → API Keys
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=
POLY_FUNDER=

# Polygon RPC (free tier works fine)
POLYGON_RPC_URL=https://rpc.ankr.com/polygon

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Wallet polling interval in seconds (default 60)
POLL_INTERVAL=60

# --- Target wallets ---
# Format: USERNAME=proxy_wallet_address
# Find proxy address: polymarket.com/@username → inspect network calls
# or use polygonscan to find the proxy from their EOA
#
# WALLET_BADIOSB=0x...
# WALLET_LUCASMEOW=0x...
# WALLET_ERASMUS=0x...
# WALLET_ELKMONKEY=0x...
# WALLET_GATORR=0x...
